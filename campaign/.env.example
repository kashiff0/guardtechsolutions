# =============================================================
# GTS Campaign Automation — Credential Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# =============================================================

# ---------------------------
# ANTHROPIC / CLAUDE
# ---------------------------
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ---------------------------
# GMAIL (OAuth2)
# ---------------------------
# 1. Go to https://console.cloud.google.com
# 2. Create project → Enable Gmail API
# 3. Create OAuth2 credentials (Desktop app)
# 4. Run: npm run auth   (one-time setup, generates refresh token)
GMAIL_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=YOUR_CLIENT_SECRET
GMAIL_REFRESH_TOKEN=1//YOUR_REFRESH_TOKEN
GMAIL_USER_EMAIL=outreach@guardtechsolutions.com

# ---------------------------
# CAMPAIGN SETTINGS
# ---------------------------
# Max emails per day (stay under Gmail's 500/day limit)
DAILY_EMAIL_LIMIT=50

# Max LinkedIn connection requests per day (LinkedIn limit ~100/week)
DAILY_LINKEDIN_LIMIT=15

# Dry run: generate messages but don't send (true/false)
DRY_RUN=true

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ---------------------------
# OPTIONAL: ENRICHMENT APIs
# ---------------------------
# Hunter.io for email finding (https://hunter.io/api)
HUNTER_API_KEY=

# Clearbit for company enrichment (https://clearbit.com)
CLEARBIT_API_KEY=
